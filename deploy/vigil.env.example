VIGIL_VAULT_PATH=/var/lib/vigil/vault
VIGIL_PORT=4000
VIGIL_GIT_REMOTE=origin
VIGIL_TZ=Europe/Berlin
VIGIL_EXCLUDE=

# OAuth 2.1 (vigil is its own authorization server, see vigil-oauth-spec.md)
VIGIL_ISSUER=https://vault.factory-lab.org
VIGIL_RESOURCE=https://vault.factory-lab.org/mcp
VIGIL_AUTH_PASSWORD=changeme-min-12-chars
VIGIL_STATE_DIR=/var/lib/vigil
