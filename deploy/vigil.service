[Unit]
Description=vigil - Markdown-Vault MCP-Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=vigil
Group=vigil
EnvironmentFile=/etc/vigil/vigil.env
WorkingDirectory=/opt/vigil
ExecStart=/opt/vigil/bin/vigil start
ExecStop=/opt/vigil/bin/vigil stop
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
